---
import '../styles/global.css';
import LogoMark from '../components/LogoMark.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Portfolio Photo - Owen',
  description = 'Portfolio photographique — voyages, architecture, sport mécanique',
  ogImage,
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Anti-flash: set theme before render -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', stored || preferred);
      })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <!-- Header — DA 04 style -->
    <header class="site-header">
      <a href="/" class="site-logo" aria-label="Owen Le Bec — Accueil">
        <LogoMark width={30} height={25} />
      </a>

      <nav class="site-nav">
        <a href="/">Portfolio</a>
        <a href="mailto:lebec.owen@gmail.com">Contact</a>

        <!-- Theme toggle -->
        <button
          id="theme-toggle"
          class="theme-toggle"
          aria-label="Changer le thème"
          title="Changer le thème"
        >
          <!-- Moon icon (shown in light mode) -->
          <svg id="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <!-- Sun icon (shown in dark mode) -->
          <svg id="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </button>
      </nav>
    </header>

    <slot />

    <script>
      import gsap from 'gsap';
      const motionOk = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (motionOk) {
        gsap.from('.site-header', {
          y: -64,
          opacity: 0,
          duration: 0.7,
          ease: 'power2.out',
        });
      }

    </script>

    <script is:inline>
      const toggle = document.getElementById('theme-toggle');
      const moon   = document.getElementById('icon-moon');
      const sun    = document.getElementById('icon-sun');

      function applyTheme(theme) {
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        if (theme === 'dark') {
          moon.style.display = 'none';
          sun.style.display  = 'block';
        } else {
          moon.style.display = 'block';
          sun.style.display  = 'none';
        }
      }

      // Init icons based on current theme
      applyTheme(document.documentElement.getAttribute('data-theme') || 'dark');

      toggle.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        applyTheme(current === 'dark' ? 'light' : 'dark');
      });
    </script>
  </body>
</html>
