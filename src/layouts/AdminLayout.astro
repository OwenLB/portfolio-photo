---
import '../styles/global.css';
import LogoMark from '../components/LogoMark.astro';
import PublishButton from '../components/admin/PublishButton.vue';

export interface Props {
  title?: string;
  currentPath?: string;
}

const { title = 'Admin', currentPath = '' } = Astro.props;
---

<!doctype html>
<html lang="fr" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;1,400&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="admin-body">

    <!-- Sidebar desktop -->
    <aside class="admin-sidebar">
      <div class="admin-sidebar-top">
        <a href="/" class="admin-logo" aria-label="Retour au site">
          <LogoMark width={24} height={20} />
        </a>
        <div class="admin-wordmark-sub">Administration</div>
      </div>

      <nav class="admin-nav">
        <a
          href="/admin"
          class={`admin-nav-item${currentPath === '/admin' ? ' active' : ''}`}
        >
          <!-- Grid icon -->
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
            <rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/>
          </svg>
          Albums
        </a>
        <a
          href="/admin/settings"
          class={`admin-nav-item${currentPath === '/admin/settings' ? ' active' : ''}`}
        >
          <!-- Sliders icon -->
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/>
            <line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/>
            <line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/>
            <line x1="17" y1="16" x2="23" y2="16"/>
          </svg>
          Paramètres
        </a>
      </nav>

      <div class="admin-sidebar-publish">
        <PublishButton client:load />
      </div>

      <div class="admin-sidebar-foot">
        <a href="/" class="admin-site-link" target="_blank" rel="noopener">
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
            <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
          photo.owenlebec.fr
        </a>
        <form method="POST" action="/api/admin-logout">
          <button type="submit" class="admin-logout-btn">
            <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
              <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Déconnexion
          </button>
        </form>
      </div>
    </aside>

    <!-- Main -->
    <div class="admin-main">
      <!-- Mobile top bar -->
      <header class="admin-topbar">
        <a href="/" class="admin-topbar-logo" aria-label="Retour au site">
          <LogoMark width={20} height={16} />
        </a>
        <a href="/" class="admin-topbar-back">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
            <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
          Site
        </a>
      </header>

      <main class="admin-content">
        <slot />
      </main>
    </div>

    <!-- Mobile bottom nav -->
    <nav class="admin-bottom-nav">
      <a
        href="/admin"
        class={`admin-bottom-item${currentPath === '/admin' ? ' active' : ''}`}
      >
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/>
        </svg>
        Albums
      </a>
      <a
        href="/admin/settings"
        class={`admin-bottom-item${currentPath === '/admin/settings' ? ' active' : ''}`}
      >
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/>
          <line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/>
          <line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/>
          <line x1="17" y1="16" x2="23" y2="16"/>
        </svg>
        Paramètres
      </a>
    </nav>

  </body>
</html>

<style>
  :root {
    --a-bg:       #f7f7f5;
    --a-surface:  #ffffff;
    --a-fg:       #0c0c0c;
    --a-fg2:      #404040;
    --a-muted:    #909090;
    --a-border:   #e6e6e3;
    --a-hover:    #f0f0ec;
    --a-active:   #eceae5;
  }

  body.admin-body {
    background: var(--a-bg);
    color: var(--a-fg);
    font-family: 'Inter', sans-serif;
    display: flex;
    height: 100vh;
    overflow: hidden;
    margin: 0;
  }

  /* ── Sidebar ────────────────────────────────────────────────────────────── */
  .admin-sidebar {
    display: none;
    flex-direction: column;
    width: 216px;
    flex-shrink: 0;
    background: var(--a-surface);
    border-right: 1px solid var(--a-border);
    height: 100vh;
  }
  @media (min-width: 768px) { .admin-sidebar { display: flex; } }

  .admin-sidebar-top {
    padding: 22px 20px 18px;
    border-bottom: 1px solid var(--a-border);
  }
  .admin-logo {
    display: inline-block;
    color: var(--a-fg);
    line-height: 0;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .admin-logo:hover { opacity: 0.6; }
  .admin-wordmark-sub {
    margin-top: 8px;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--a-muted);
  }

  .admin-nav {
    padding: 10px 10px;
    display: flex;
    flex-direction: column;
    gap: 1px;
    flex: 1;
  }
  .admin-nav-item {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 7px 10px;
    border-radius: 5px;
    font-size: 12.5px;
    font-weight: 400;
    color: var(--a-muted);
    text-decoration: none;
    transition: background 0.1s, color 0.1s;
    letter-spacing: 0.01em;
  }
  .admin-nav-item:hover {
    background: var(--a-hover);
    color: var(--a-fg2);
  }
  .admin-nav-item.active {
    background: var(--a-active);
    color: var(--a-fg);
    font-weight: 500;
  }
  .admin-nav-item svg { flex-shrink: 0; opacity: 0.7; }
  .admin-nav-item.active svg { opacity: 1; }

  .admin-sidebar-publish {
    padding: 12px 10px;
    border-top: 1px solid var(--a-border);
  }

  .admin-sidebar-foot {
    padding: 16px 20px;
    border-top: 1px solid var(--a-border);
  }
  .admin-site-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--a-muted);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }
  .admin-site-link:hover { color: var(--a-fg); }

  .admin-logout-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--a-muted);
    background: none;
    border: none;
    padding: 0;
    margin-top: 8px;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }
  .admin-logout-btn:hover { color: var(--a-fg); }

  /* ── Main ───────────────────────────────────────────────────────────────── */
  .admin-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-width: 0;
  }

  .admin-topbar {
    display: none;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    height: 48px;
    background: var(--a-surface);
    border-bottom: 1px solid var(--a-border);
    flex-shrink: 0;
  }
  @media (max-width: 767px) { .admin-topbar { display: flex; } }

  .admin-topbar-logo {
    display: inline-block;
    color: var(--a-fg);
    line-height: 0;
    text-decoration: none;
  }
  .admin-topbar-back {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    color: var(--a-muted);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 0.15s;
  }
  .admin-topbar-back:hover { color: var(--a-fg); }

  .admin-content {
    flex: 1;
    overflow-y: auto;
    padding: 44px 52px;
  }
  @media (max-width: 767px) { .admin-content { padding: 24px 20px 80px; } }

  /* ── Mobile bottom nav ──────────────────────────────────────────────────── */
  .admin-bottom-nav {
    display: none;
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: var(--a-surface);
    border-top: 1px solid var(--a-border);
    z-index: 40;
  }
  @media (max-width: 767px) { .admin-bottom-nav { display: flex; } }

  .admin-bottom-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 10px 0 12px;
    font-size: 9.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--a-muted);
    text-decoration: none;
    gap: 4px;
    transition: color 0.15s;
  }
  .admin-bottom-item.active { color: var(--a-fg); }
</style>
