---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Nouvel album" currentPath="/admin/album/new">

  <div class="page-header">
    <a href="/admin" class="back-link">
      <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      Albums
    </a>
    <h1 class="page-title">Créer un album</h1>
  </div>

  <form id="new-album-form" class="album-form">
    <div class="form-field">
      <label for="title" class="form-label">Titre <span class="required">*</span></label>
      <input id="title" name="title" type="text" required placeholder="Ex : Tokyo 2026" class="form-input" />
    </div>

    <div class="form-field">
      <label for="slug" class="form-label">
        Slug <span class="form-label-hint">(auto-généré)</span>
      </label>
      <input id="slug" name="slug" type="text" placeholder="tokyo-2026" class="form-input form-input--mono" />
    </div>

    <div class="form-field">
      <label for="description" class="form-label">Description</label>
      <textarea id="description" name="description" rows="3" placeholder="Description optionnelle" class="form-input form-textarea"></textarea>
    </div>

    <div id="form-error" class="form-error" style="display:none"></div>

    <div class="form-actions">
      <button type="submit" id="submit-btn" class="btn-primary">Créer l'album</button>
      <a href="/admin" class="btn-ghost">Annuler</a>
    </div>
  </form>

</AdminLayout>

<style>
  .page-header {
    margin-bottom: 32px;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: #909090;
    text-decoration: none;
    transition: color 0.15s;
    margin-bottom: 12px;
  }
  .back-link:hover { color: #0c0c0c; }
  .page-title {
    font-size: 20px;
    font-weight: 500;
    color: #0c0c0c;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .album-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 480px;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .form-label {
    font-size: 11px;
    color: #909090;
    letter-spacing: 0.04em;
  }
  .form-label-hint {
    color: #b0b0aa;
    font-weight: 400;
  }
  .required { color: #e53e3e; }

  .form-input {
    border: 1px solid #e6e6e3;
    border-radius: 3px;
    padding: 8px 10px;
    font-size: 13px;
    font-family: 'Inter', sans-serif;
    color: #0c0c0c;
    background: #fff;
    transition: border-color 0.15s;
    box-sizing: border-box;
    width: 100%;
  }
  .form-input:focus { outline: none; border-color: #a0a09c; }
  .form-input--mono { font-family: 'Inter', monospace; color: #505050; }
  .form-textarea { resize: none; }

  .form-error {
    font-size: 12px;
    color: #c53030;
    background: #fff5f5;
    border: 1px solid #fca5a5;
    border-radius: 3px;
    padding: 8px 12px;
  }

  .form-actions {
    display: flex;
    gap: 8px;
    padding-top: 4px;
  }
  .btn-primary {
    padding: 7px 18px;
    background: #0c0c0c;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-primary:hover:not(:disabled) { opacity: 0.8; }
  .btn-primary:disabled { opacity: 0.4; cursor: default; }
  .btn-ghost {
    padding: 7px 16px;
    background: none;
    border: 1px solid #e6e6e3;
    border-radius: 4px;
    font-size: 12px;
    font-family: 'Inter', sans-serif;
    color: #606060;
    text-decoration: none;
    transition: background 0.15s;
  }
  .btn-ghost:hover { background: #f7f7f5; }
</style>

<script>
function slugify(title: string): string {
  return title
    .toLowerCase()
    .normalize('NFD')
    .replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}

const form       = document.getElementById('new-album-form') as HTMLFormElement;
const titleInput = document.getElementById('title') as HTMLInputElement;
const slugInput  = document.getElementById('slug') as HTMLInputElement;
const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement;
const errorDiv   = document.getElementById('form-error') as HTMLDivElement;

titleInput?.addEventListener('input', () => {
  if (!slugInput.dataset.manual) slugInput.value = slugify(titleInput.value);
});
slugInput?.addEventListener('input', () => {
  slugInput.dataset.manual = 'true';
});

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  submitBtn.disabled = true;
  submitBtn.textContent = 'Création…';
  errorDiv.style.display = 'none';

  try {
    const res = await fetch('/api/albums', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        title: titleInput.value,
        slug: slugInput.value || slugify(titleInput.value),
        description: (document.getElementById('description') as HTMLTextAreaElement)?.value || undefined,
      }),
    });
    if (!res.ok) {
      const err = await res.json();
      throw new Error(err.error || 'Erreur');
    }
    const album = await res.json();
    window.location.href = `/admin/album/${album.slug}`;
  } catch (err: any) {
    errorDiv.textContent = err.message;
    errorDiv.style.display = 'block';
    submitBtn.disabled = false;
    submitBtn.textContent = "Créer l'album";
  }
});
</script>
