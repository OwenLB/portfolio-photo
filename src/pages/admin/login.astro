---
export const prerender = false;
import LogoMark from '../../components/LogoMark.astro';

const error = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="fr" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Connexion — Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="login-wrap">
      <div class="login-card">
        <div class="login-logo">
          <LogoMark width={28} height={23} />
        </div>
        <h1 class="login-title">Administration</h1>

        {error && (
          <div class="login-error">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            Mot de passe incorrect
          </div>
        )}

        <form method="POST" action="/api/admin-login" class="login-form">
          <div class="login-field">
            <label for="password" class="login-label">Mot de passe</label>
            <input
              id="password"
              name="password"
              type="password"
              class="login-input"
              autocomplete="current-password"
              autofocus
              required
            />
          </div>
          <button type="submit" class="login-btn">Connexion</button>
        </form>
      </div>
    </div>
  </body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #f7f7f5;
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .login-wrap {
    width: 100%;
    max-width: 360px;
    padding: 20px;
  }

  .login-card {
    background: #fff;
    border: 1px solid #e6e6e3;
    border-radius: 6px;
    padding: 36px 32px 32px;
  }

  .login-logo {
    margin-bottom: 16px;
    color: #0c0c0c;
    line-height: 0;
  }

  .login-title {
    font-size: 14px;
    font-weight: 500;
    color: #0c0c0c;
    letter-spacing: 0.01em;
    margin-bottom: 28px;
  }

  .login-error {
    display: flex;
    align-items: center;
    gap: 7px;
    background: #fff5f5;
    border: 1px solid #fed7d7;
    color: #c53030;
    font-size: 12px;
    padding: 9px 12px;
    border-radius: 4px;
    margin-bottom: 20px;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .login-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .login-label {
    font-size: 11px;
    font-weight: 500;
    color: #606060;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .login-input {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid #e6e6e3;
    border-radius: 4px;
    font-size: 13px;
    font-family: 'Inter', sans-serif;
    color: #0c0c0c;
    background: #fff;
    outline: none;
    transition: border-color 0.15s;
  }
  .login-input:focus { border-color: #909090; }

  .login-btn {
    width: 100%;
    padding: 9px 16px;
    background: #0c0c0c;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 12.5px;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: opacity 0.15s;
    margin-top: 4px;
  }
  .login-btn:hover { opacity: 0.8; }
</style>
