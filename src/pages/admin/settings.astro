---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import PublishButton from '../../components/admin/PublishButton.vue';

const hookConfigured = !!import.meta.env.CF_PAGES_BUILD_HOOK;
const currentPath = '/admin/settings';
---

<AdminLayout title="Paramètres" currentPath={currentPath}>

  <div class="page-header">
    <h1 class="page-title">Paramètres</h1>
  </div>

  <!-- Publish -->
  <section class="settings-section">
    <h2 class="settings-section-title">Republier le site</h2>
    <p class="settings-section-desc">
      Les pages publiques sont générées statiquement. Après toute modification
      (photos, visibilité, ordre), publie pour mettre à jour le site en ligne.
    </p>
    <PublishButton client:load />
  </section>

  <!-- Deploy hook config -->
  <section class="settings-section">
    <h2 class="settings-section-title">Configuration du webhook</h2>

    <div class={`hook-status ${hookConfigured ? 'hook-status--ok' : 'hook-status--warn'}`}>
      <span class="hook-dot" />
      {hookConfigured
        ? 'Variable CF_PAGES_BUILD_HOOK configurée'
        : 'Variable CF_PAGES_BUILD_HOOK non configurée — le bouton "Publier" est en mode démo'}
    </div>

    <p class="settings-label">Comment configurer :</p>
    <ol class="settings-steps">
      <li>
        Dans Netlify → <strong>Site configuration</strong> → <strong>Build &amp; deploy</strong>
        → <strong>Build hooks</strong> → <strong>Add build hook</strong>
      </li>
      <li>
        Nomme-le <code class="settings-code">admin-publish</code>,
        branche <code class="settings-code">main</code>
      </li>
      <li>Copie l'URL générée (format <code class="settings-code">https://api.netlify.com/build_hooks/…</code>)</li>
      <li>
        Toujours dans Netlify → <strong>Environment variables</strong> → ajoute :<br/>
        Clé : <code class="settings-code">CF_PAGES_BUILD_HOOK</code><br/>
        Valeur : l'URL copiée
      </li>
      <li>Déclenche un nouveau déploiement pour que la variable soit prise en compte</li>
    </ol>
  </section>

</AdminLayout>

<style>
  .page-header {
    margin-bottom: 32px;
  }
  .page-title {
    font-size: 20px;
    font-weight: 500;
    color: #0c0c0c;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .settings-section {
    background: #fff;
    border: 1px solid #e6e6e3;
    padding: 20px 24px;
    margin-bottom: 16px;
    max-width: 560px;
  }
  .settings-section-title {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #909090;
    margin: 0 0 8px;
  }
  .settings-section-desc {
    font-size: 12.5px;
    color: #707070;
    line-height: 1.6;
    margin: 0 0 16px;
  }

  .hook-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    margin-bottom: 16px;
    padding: 8px 12px;
    border-radius: 4px;
  }
  .hook-status--ok   { background: #f0fdf4; color: #166534; }
  .hook-status--warn { background: #fffbeb; color: #78610a; }
  .hook-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    background: currentColor;
  }

  .settings-label {
    font-size: 11px;
    font-weight: 500;
    color: #606060;
    margin: 0 0 8px;
  }
  .settings-steps {
    margin: 0;
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 12px;
    color: #606060;
    line-height: 1.6;
  }
  .settings-code {
    background: #f5f5f3;
    border: 1px solid #e6e6e3;
    padding: 1px 5px;
    border-radius: 3px;
    font-family: 'Inter', monospace;
    font-size: 10.5px;
    color: #404040;
  }
</style>
