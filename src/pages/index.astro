---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getVisibleAlbums } from '../lib/albums';
const albums = await getVisibleAlbums();
---

<BaseLayout title="Owen Le Bec — Photographies" description="Portfolio photographique de Owen Le Bec.">

  <!-- Hero -->
  <section class="hero" id="hero">
    <canvas class="hero-grain" aria-hidden="true"></canvas>
    <div class="hero-inner">
      <div class="hero-meta">
        <span class="hero-eyebrow">Owen Le Bec</span>
        <span class="hero-badge">Développeur</span>
      </div>
      <h1 class="hero-title">
        <span class="hero-line-wrap"><span class="hero-line">Portfolio</span></span>
        <span class="hero-line-wrap"><em class="hero-line hero-line--italic">Photo</em></span>
      </h1>
      <div class="hero-divider"></div>
    </div>
    <div class="hero-avatar">
      <img src="/profile.webp" alt="Owen Le Bec" loading="eager" decoding="async" />
    </div>
    <div class="hero-bg-text" aria-hidden="true">Photo</div>
  </section>

  <!-- Album rows -->
  {albums.length === 0 ? (
    <div class="empty">
      <p>Aucun album pour le moment.</p>
    </div>
  ) : (
    <section class="albums">
      {albums.map((album, i) => (
        <a
          href={`/album/${album.slug}`}
          class={`album-row${i % 2 === 1 ? ' reverse' : ''}`}
        >
          <div class="album-row-img">
            <img
              src={album.coverUrl ?? ''}
              alt={album.title}
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </div>
          <div class="album-row-info">
            <div class="album-row-num">
              {String(i + 1).padStart(2, '0')} / {String(albums.length).padStart(2, '0')}
            </div>
            <h2 class="album-row-title">
              {album.title.split(' ').length > 1
                ? <>{album.title.split(' ').slice(0, -1).join(' ')}<br/><em>{album.title.split(' ').slice(-1)}</em></>
                : album.title
              }
            </h2>
            <p class="album-row-count">
              {album.photoCount} photo{album.photoCount > 1 ? 's' : ''}
            </p>
            <span class="album-row-cta">Voir l'album</span>
          </div>
        </a>
      ))}
    </section>
  )}

  <!-- Footer -->
  <footer class="site-footer">
    <span>© Owen LE BEC · {new Date().getFullYear()}</span>
    <span>Tous droits réservés</span>
  </footer>
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────── */
  .hero {
    min-height: 90vh;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: stretch;
    overflow: hidden;
    position: relative;
  }

  .hero-grain {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .hero-inner {
    flex: 1;
    padding: 120px 64px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 44px;
  }

  .hero-eyebrow {
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  .hero-badge {
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-muted);
    opacity: 0.45;
    padding-left: 20px;
    border-left: 1px solid var(--border);
  }

  .hero-title {
    font-family: 'Libre Baskerville', serif;
    font-size: clamp(72px, 11vw, 152px);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--fg);
  }

  /* Clip wrapper for slide-up reveal */
  .hero-line-wrap {
    display: block;
    overflow: hidden;
    padding-bottom: 0.06em;
  }

  .hero-line {
    display: block;
  }

  .hero-line--italic {
    font-style: italic;
    color: var(--fg-muted);
  }

  .hero-divider {
    width: 48px;
    height: 1px;
    background: var(--fg-muted);
    opacity: 0.4;
    margin: 40px 0 28px;
    transform-origin: left center;
  }

  .hero-avatar {
    flex-shrink: 0;
    width: clamp(280px, 38%, 520px);
    align-self: stretch;
    position: relative;
    z-index: 1;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 38%);
    mask-image: linear-gradient(to right, transparent 0%, black 38%);
  }

  .hero-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Large decorative outline text */
  .hero-bg-text {
    position: absolute;
    right: -0.04em;
    bottom: -0.18em;
    font-family: 'Libre Baskerville', serif;
    font-size: clamp(160px, 22vw, 360px);
    font-weight: 700;
    font-style: italic;
    color: transparent;
    -webkit-text-stroke: 1px var(--fg-muted);
    opacity: 0.1;
    pointer-events: none;
    user-select: none;
    z-index: 1;
    line-height: 1;
  }

  /* ── Albums ───────────────────────────────────────────────────────── */
  .albums {
    border-top: 1px solid var(--border);
  }

  a.album-row {
    text-decoration: none;
    color: inherit;
    display: grid;
  }

  /* ── Empty / Footer ───────────────────────────────────────────────── */
  .empty {
    padding: 120px 48px;
    text-align: center;
    color: var(--fg-muted);
    font-size: 14px;
  }

  .site-footer {
    padding: 28px 48px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--fg-muted);
    letter-spacing: 0.06em;
  }

  /* ── Mobile ───────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      flex-direction: column;
    }
    .hero-inner {
      padding: 64px 24px 48px;
    }
    .hero-avatar {
      display: none;
    }
    .hero-bg-text {
      display: none;
    }
    .site-footer {
      padding: 24px 20px;
    }
  }
</style>

<script>
  // ── Hero grain ──────────────────────────────────────────────────────
  {
    const canvas = document.querySelector('.hero-grain') as HTMLCanvasElement;
    const ctx    = canvas.getContext('2d')!;
    const FPS    = 24;
    const RADIUS = 260;

    let mouse  = { x: -9999, y: -9999 };
    let lastTs = 0;

    function resize() {
      canvas.width  = canvas.offsetWidth  || canvas.parentElement?.clientWidth  || 1440;
      canvas.height = canvas.offsetHeight || canvas.parentElement?.clientHeight || 800;
    }

    function isDark() {
      return document.documentElement.getAttribute('data-theme') !== 'light';
    }

    function drawHeroGrain() {
      const { width: w, height: h } = canvas;
      if (!w || !h) return;

      const img  = ctx.createImageData(w, h);
      const d    = img.data;
      const dark = isDark();
      const gv   = dark ? 255 : 0;
      const r2   = RADIUS * RADIUS;

      for (let i = 0; i < d.length; i += 4) {
        if (Math.random() > 0.5) continue;

        const idx = i >> 2;
        const x   = idx % w;
        const y   = (idx / w) | 0;

        const dx   = x - mouse.x;
        const dy   = y - mouse.y;
        const t    = Math.max(0, 1 - (dx * dx + dy * dy) / r2);
        const spot = t * t * (3 - 2 * t);

        const alpha = (0.07 + spot * 0.14) * Math.random() * 255;

        d[i] = d[i + 1] = d[i + 2] = gv;
        d[i + 3] = alpha;
      }

      ctx.putImageData(img, 0, 0);
    }

    function grainLoop(ts: number) {
      requestAnimationFrame(grainLoop);
      if (ts - lastTs < 1000 / FPS) return;
      lastTs = ts;
      drawHeroGrain();
    }

    const hero = document.querySelector('.hero')!;
    hero.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });
    hero.addEventListener('mouseleave', () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });

    new ResizeObserver(resize).observe(canvas);
    resize();
    requestAnimationFrame(grainLoop);
  }

  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const motionOk = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (motionOk) {
    // ── Hero entrance timeline ──────────────────────────────────────
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    tl.from('.hero-eyebrow', { y: 18, opacity: 0, duration: 0.7 })
      .from('.hero-badge',   { opacity: 0, duration: 0.5 }, '-=0.35')
      .from('.hero-line',    { y: '105%', duration: 1, stagger: 0.14 }, '-=0.35')
      .from('.hero-divider', { scaleX: 0, opacity: 0, duration: 0.8, ease: 'power2.inOut' }, '-=0.35')
      .from('.hero-avatar',  { x: 50, opacity: 0, duration: 1.2, ease: 'power2.out' }, 0.1)
      .from('.hero-bg-text', { x: 80, opacity: 0, duration: 1.8, ease: 'power2.out' }, 0);

    // ── Hero parallax ───────────────────────────────────────────────
    gsap.to('.hero-bg-text', {
      y: -100,
      ease: 'none',
      scrollTrigger: {
        trigger: '.hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 1.2,
      },
    });

    gsap.to('.hero-avatar img', {
      y: 60,
      ease: 'none',
      scrollTrigger: {
        trigger: '.hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 1,
      },
    });

    // ── Footer reveal ────────────────────────────────────────────────
    gsap.from('.site-footer', {
      opacity: 0,
      y: 20,
      duration: 0.8,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '.site-footer',
        start: 'top 95%',
        once: true,
      },
    });

    // ── Album rows — scroll-triggered slide in ──────────────────────
    (gsap.utils.toArray('.album-row') as Element[]).forEach((row) => {
      const el = row as HTMLElement;
      const img  = el.querySelector('.album-row-img');
      const info = el.querySelector('.album-row-info');
      const isReverse = el.classList.contains('reverse');

      const shared: ScrollTrigger.Vars = {
        trigger: el,
        start: 'top 78%',
        once: true,
      };

      if (img) {
        gsap.from(img, {
          x: isReverse ? 56 : -56,
          opacity: 0,
          duration: 1,
          ease: 'power2.out',
          scrollTrigger: shared,
        });
      }

      if (info) {
        gsap.from(info, {
          x: isReverse ? -36 : 36,
          opacity: 0,
          duration: 0.9,
          delay: 0.14,
          ease: 'power2.out',
          scrollTrigger: shared,
        });
      }
    });
  }
</script>
